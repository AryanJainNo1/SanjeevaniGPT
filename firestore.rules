rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation Blueprint: User
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email']) && 
             data.keys().size() == 2 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 200;
    }

    // Validation Blueprint: Conversation
    function isValidConversation(data, userId) {
      return data.keys().hasAll(['title', 'evi', 'color', 'lastUpdated', 'userId']) &&
             data.keys().size() == 5 &&
             data.userId == userId &&
             data.title is string && data.title.size() <= 200 &&
             data.evi is number && data.evi >= 0 && data.evi <= 100 &&
             data.color is string && data.color.size() <= 20 &&
             data.lastUpdated is string;
    }

    // Validation Blueprint: Message
    function isValidMessage(data) {
      return data.keys().hasAll(['role', 'text', 'timestamp']) &&
             data.keys().size() == 3 &&
             data.role in ['user', 'model'] &&
             data.text is string && data.text.size() <= 5000 &&
             data.timestamp is string;
    }

    // Validation Blueprint: MoodEntry
    function isValidMoodEntry(data, userId) {
      return data.keys().hasAll(['userId', 'mood', 'note', 'date']) &&
             data.keys().size() == 4 &&
             data.userId == userId &&
             data.mood is number && data.mood >= 1 && data.mood <= 5 &&
             data.note is string && data.note.size() <= 1000 &&
             data.date is string;
    }

    // Validation Blueprint: GratitudeEntry
    function isValidGratitudeEntry(data, userId) {
      return data.keys().hasAll(['userId', 'text', 'date']) &&
             data.keys().size() == 3 &&
             data.userId == userId &&
             data.text is string && data.text.size() <= 1000 &&
             data.date is string;
    }

    // Collection matches
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                      request.resource.data.email == resource.data.email;

      match /conversations/{convId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(convId);
        allow create: if isOwner(userId) && isValidId(convId) && isValidConversation(request.resource.data, userId);
        allow update: if isOwner(userId) && isValidId(convId) && isValidConversation(request.resource.data, userId);
        allow delete: if isOwner(userId) && isValidId(convId);

        match /messages/{msgId} {
          allow list: if isOwner(userId);
          allow get: if isOwner(userId) && isValidId(msgId);
          allow create: if isOwner(userId) && isValidId(msgId) && isValidMessage(request.resource.data);
        }
      }

      match /moodHistory/{moodId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(moodId);
        allow create: if isOwner(userId) && isValidId(moodId) && isValidMoodEntry(request.resource.data, userId);
        allow delete: if isOwner(userId) && isValidId(moodId);
      }

      match /gratitudeList/{gratitudeId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(gratitudeId);
        allow create: if isOwner(userId) && isValidId(gratitudeId) && isValidGratitudeEntry(request.resource.data, userId);
        allow delete: if isOwner(userId) && isValidId(gratitudeId);
      }
    }
  }
}
